# Elly server configuration
#
# Copy this file to `.env` in the same directory (server/.env) and fill
# in the values you need. Nothing here is required to boot the app --
# every value has a sane local-only default -- except OPENAI_API_KEY,
# without which the in-app chat feature will show a friendly error
# message instead of crashing.
#
# Never commit your real `.env` file. It's already covered by
# .gitignore (`.env`, `.env.*`, with an explicit allowance for this
# `.env.example`).

# --- Local access token (NOT set here) -----------------------------------
#
# Elly generates a local API access token automatically on first boot
# and prints it once to the terminal/log -- there is no env var for
# this. It's stored in your OS keychain (or a locked-down .elly_token
# file if no keyring backend is available, e.g. inside Docker). Paste
# it into the dashboard once when prompted; see SECURITY.md for
# details.

# --- LLM / in-app chat -------------------------------------------------

# Required for the in-app chat feature (web UI chat panel + future
# Telegram bot). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Which OpenAI-compatible model to use for chat tool-calling.
# Default: gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini

# Only used when the LLM provider is switched to "ollama" in Settings
# (see the in-app onboarding wizard / Settings tab -- this is a runtime
# choice stored in the database, not an env var). Override these only
# if your Ollama server runs on a non-default host/port -- e.g. another
# machine on your LAN, or a different port inside Docker.
# ELLY_OLLAMA_BASE_URL=http://localhost:11434/v1
# ELLY_OLLAMA_MODEL=llama3.1

# --- Telegram remote access (optional) -----------------------------------
#
# Entirely optional -- the dashboard, MCP server, and REST API all work
# fine without this. The easiest way to set this up is now the
# dashboard's Settings tab (paste a bot token from @BotFather there,
# then restart when prompted) -- elly-api spawns/manages the bot as
# its own child process automatically once a token is configured, no
# separate `elly-telegram` process to run yourself. This env var still
# works too, as a fallback for scripted/headless setups (the
# in-database value from Settings takes precedence if both are set).
# Pairing (linking a specific Telegram chat) always happens from the
# dashboard's Settings tab (a one-time 6-digit code you send to the
# bot) -- never configure a chat ID here directly.
ELLY_TELEGRAM_BOT_TOKEN=

# --- Data storage --------------------------------------------------------

# Override where Elly stores its local data (SQLite DB, etc). Defaults
# to ~/Library/Application Support/Elly on macOS. Never point this at a
# path inside this repo or inside an iCloud-synced folder -- a live
# SQLite file being synced while open is a known corruption risk.
# ELLY_DATA_DIR=

# Override the full SQLite database file path directly (takes
# precedence over ELLY_DATA_DIR for the DB file specifically).
# ELLY_DB_PATH=

# --- REST API --------------------------------------------------------

# Port for the local REST API (elly-api). The host is hardcoded to
# 127.0.0.1 in code and is not configurable via env var -- this is a
# deliberate safety rail, see PLAN.md section 5.
# ELLY_API_PORT=8765

# Comma-separated list of origins allowed to call the REST API with
# credentials. Only matters during frontend development (the Vite dev
# server runs on a different port than the API). In production the
# built PWA is served by the same process (same-origin, no CORS
# needed).
# ELLY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Override where the built PWA (web/dist) is served from. Only needed
# if you build the frontend to a non-default location.
# ELLY_WEB_DIST=

# Cap on incoming request body size in bytes (defense-in-depth; see
# SECURITY.md). Default is 2 MiB, generous for a long diary entry.
# ELLY_MAX_BODY_BYTES=2097152
